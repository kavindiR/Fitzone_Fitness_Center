{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "member/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "staff/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.php" },
    { "src": "/([^.]*)", "dest": "/$1.php" }
  ]
}

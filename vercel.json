{
  "version": 2,
  "builds": [
    {
      "src": "*.php",
      "use": "@vercel/php"
    },
    {
      "src": "admin/*.php",
      "use": "@vercel/php"
    },
    {
      "src": "member/*.php",
      "use": "@vercel/php"
    },
    {
      "src": "staff/*.php",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "src": "/([^.]*)",
      "dest": "/$1.php"
    }
  ]
}
